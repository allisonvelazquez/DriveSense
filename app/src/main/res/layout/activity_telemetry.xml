<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="12dp"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvTelemetryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Telemetría"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">

        <Button
            android:id="@+id/btnDemoTelemetry"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Insertar demo" />

        <Button
            android:id="@+id/btnStartRecording"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Iniciar grabación"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnStopRecording"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Detener"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnExportCSV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exportar CSV"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Últimos registros" android:textStyle="bold" android:layout_marginTop="12dp"/>

    <ListView
        android:id="@+id/lvTelemetry"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp" />
</LinearLayout>
