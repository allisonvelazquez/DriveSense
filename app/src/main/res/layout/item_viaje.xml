<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="12dp"
    android:layout_width="match_parent" android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvInicioViaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inicio"
        android:textStyle="bold"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/tvRutaViaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ruta"
        android:textSize="13sp"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/tvResumenViaje"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Resumen"/>

        <TextView
            android:id="@+id/tvKmViaje"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0.0 km"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvGco2Viaje"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0 gCO2"/>
    </LinearLayout>
</LinearLayout>
