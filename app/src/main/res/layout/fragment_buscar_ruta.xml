<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:backgroundTint="#FBFBFB"
    tools:context=".BuscarRutaFragment">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:text="Buscar ruta"
        android:textAlignment="center"
        android:textColor="#090808"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Fila 1: Autocomplete Origen (izquierda) + Botón Origen (derecha) -->

    <!-- Fila 2: Autocomplete Destino (izquierda) + Botón Destino (derecha) -->

    <fragment
        android:id="@+id/autocompleteDestino"
        android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/btnAgregarDestino"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/autocompleteOrigen" />

    <Button
        android:id="@+id/btnAgregarOrigen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#19571C"
        android:text="Agregar Origen"
        android:textColor="#FDFDFD"
        app:layout_constraintBottom_toBottomOf="@id/autocompleteOrigen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/autocompleteOrigen"
        app:layout_constraintTop_toTopOf="@id/autocompleteOrigen"
        app:layout_constraintVertical_bias="0.413" />

    <fragment
        android:id="@+id/autocompleteOrigen"
        android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@+id/btnAgregarOrigen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

    <!-- Mapa: altura fija más pequeña para dejar espacio abajo -->

    <!-- Botón fijo abajo: Calcular forma -->

    <Button
        android:id="@+id/btnAgregarDestino"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#19571C"
        android:text="Agregar Destino"
        android:textColor="#FDFDFD"
        android:textColorLink="#0D4E0E"
        app:layout_constraintBottom_toBottomOf="@id/autocompleteDestino"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/autocompleteDestino"
        app:layout_constraintTop_toTopOf="@id/autocompleteDestino"
        app:layout_constraintVertical_bias="0.448" />

    <fragment
        android:id="@+id/mapContainer"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="386dp"
        android:layout_height="351dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="8dp"
        android:background="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.444"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/autocompleteDestino" />

    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:layout_marginTop="17dp"
        android:backgroundTint="#19571C"
        android:text="Iniciar"
        android:textColor="#FDFDFD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.333"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mapContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>
